# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN="Your Sentry DSN goes here"

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG="organization-name"

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT="project-name"

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN="Your Sentry authentication token goes here"
SENTRY_ENVIRONMENT="staging | production"

# Base URL of the Spendrift API, including the version prefix.
# Local backend: http://localhost:8000/api/v1
VITE_API_BASE_URL="http://localhost:8000/api/v1"


